APP_ENV=development
APP_MODE=api
HTTP_ADDR=:8080
DATABASE_URL='postgres://postgres@localhost/simple_log_analyser?host=/tmp/pgsla&sslmode=disable'
UPLOAD_DIR='/absolute/path/to/cyber_app/backend/data/uploads'
GOCACHE='/tmp/go-build'
SESSION_TTL='2h'

# Comma-separated list of origins allowed to call the API with credentials.
# In production, set this to your deployed frontend URL, e.g.:
#   ALLOWED_ORIGINS='https://your-app.vercel.app'
ALLOWED_ORIGINS='http://127.0.0.1:5173,http://localhost:5173'

ANTHROPIC_API_KEY=''
CLAUDE_MODEL='claude-3-5-haiku-latest'
